A) Em todas as subpastas:

1. Pra *qm:

find . -type f -name "*.qmd" -exec bash -c 'mv "$0" "${0%.qmd}.qm"' {} \;

2. Pra *qmd:

find . -type f -name "*.qm" -exec bash -c 'mv "$0" "${0%.qm}.qmd"' {} \;


B) Em uma pasta apenas:

1. Pra   *qmd: 

for f in *.qm; do
  mv -- "$f" "${f%.qm}.qmd"
done

2. Pra *qm :

for f in *.qmd; do
  mv -- "$f" "${f%.qmd}.qm"
done

